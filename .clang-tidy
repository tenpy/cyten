Checks: 'cppcoreguidelines-*'
# TODO: also include modernize-* checks eventually

# Treat specific warnings as errors:
# WarningsAsErrors: 'cppcoreguidelines-*'

CheckOptions:
  cppcoreguidelines-special-member-functions.AllowSoleDefaultDtor: true
  readability-magic-numbers.IgnoredIntegerValues: [0,1,2,3,4,8,10,16,32,64,128]
  readability-magic-numbers.IgnoredFloatingPointValues: [1., 2., 1.e-16]
